# Cloudflare Pages headers.
# The exported OG image has no file extension, so force its content type
# (and cache it) for social scrapers.
/opengraph-image
  Content-Type: image/png
  Cache-Control: public, max-age=86400

# Private prospect previews: keep every /p/ page out of search engines.
/p/*
  X-Robots-Tag: noindex, nofollow

# Private signing pages: never indexed.
/agree/*
  X-Robots-Tag: noindex, nofollow
